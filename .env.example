# Bocatas Digital — Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase Project
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Manus OAuth
VITE_OAUTH_PORTAL_URL=https://oauth.manus.space
VITE_APP_ID=<your-app-id>

# Database (direct connection — for migrations)
DATABASE_URL=postgresql://postgres:<your-db-password>@db.your-project.supabase.co:5432/postgres

# Test Users (Gate 0 seed — remove in production)
# superadmin@bocatas.test  / BocatasSuper2026!
