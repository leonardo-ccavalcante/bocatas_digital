# Bocatas Digital — environment template
# Copy to .env.local and fill in. NEVER commit .env.local.

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Public Supabase project URL + anon key. Local default values are auto-generated
# by `supabase start` — copy them from `supabase status` output.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# Manus OAuth app id (from Manus dashboard → OAuth apps).
VITE_APP_ID=

# OAuth callback portal URL. Production: https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=http://localhost:3001

# ─── Server / tRPC ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Optional: override the host shown in the dev startup banner. Defaults to localhost.
DEV_HOST=localhost

# Cookie / JWT signing secret (64+ random bytes, base64). Generate locally:
#   openssl rand -base64 64
JWT_SECRET=

# Manus user database (MySQL via drizzle-orm). See drizzle/README.md.
DATABASE_URL=mysql://user:pass@localhost:3306/bocatas_auth

# Manus OAuth server (production: https://oauth.manus.im)
OAUTH_SERVER_URL=http://localhost:3001
OWNER_OPEN_ID=

# Public app URL (used in webhook payloads + email links). Falls back to a
# hard-coded Manus URL in production builds — set explicitly here in dev.
APP_URL=http://localhost:3000

# Manus Forge API (used by OCR edge function). Empty → OCR disabled.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Supabase service role (server-only, NEVER expose to the client) ─────────
# Used by server/lib/supabase/server.ts (createAdminClient) and one-shot scripts.
# Local default value is auto-generated by `supabase start`.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=

# ─── Test users (seeded by `supabase db reset`) ──────────────────────────────
# These are LOCAL-ONLY credentials documented for developer convenience. Production
# uses Manus OAuth exclusively.
# See docs/dev-setup.md for credentials + how to recreate them if seeding fails.

# ─── Optional: enable RLS integration tests in CI ────────────────────────────
# Set to "1" once 4 seeded auth.users with role claims are confirmed in your
# local Supabase. Defaults off — see server/__tests__/rls-pii.integration.test.ts.
RLS_TESTS_ENABLED=

# ─── Optional: React Compiler (RC) ──────────────────────────────────────────
# Set to "1" to enable babel-plugin-react-compiler. Default OFF.
# See docs/runbooks/react-compiler-rollout.md before flipping in production —
# requires a full QA pass on real low-end Android devices first.
VITE_REACT_COMPILER=
